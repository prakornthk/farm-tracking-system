# Farm Tracking System - Environment Variables

# App
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost

# Database
MARIADB_ROOT_PASSWORD=your_secure_root_password
MARIADB_DATABASE=farm_tracking
MARIADB_USER=farm_user
MARIADB_PASSWORD=your_secure_db_password

# Redis (optional)
REDIS_HOST=redis
REDIS_PORT=6379

# Frontend build variables
VITE_LINE_CLIENT_ID=your_line_channel_id
VITE_API_BASE=https://api.farm.localhost

# LINE LIFF
LIFF_ID=your_liff_id_here
